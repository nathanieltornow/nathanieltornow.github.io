---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Nathaniel Tornow — Academic Homepage</title>
  </head>
  <body class="bg-gradient-to-b from-stone-100 via-white to-stone-100 text-stone-900 min-h-screen">
    <main class="max-w-6xl mx-auto px-6 py-12 lg:py-16">
      <div class="grid lg:grid-cols-[320px,1fr] gap-10">
        <!-- Sidebar / Profile Card -->
        <aside class="lg:sticky top-8 h-fit bg-white/90 backdrop-blur rounded-2xl border border-stone-200 shadow-md p-6 flex flex-col gap-6">
          <div class="flex flex-col items-center text-center gap-4">
            <img src="/avatar.png" alt={cvData.name} class="w-28 h-28 rounded-2xl object-cover border border-stone-200 shadow-sm" />
            <div>
              <h1 class="text-3xl font-bold leading-tight">{cvData.name}</h1>
              <p class="text-stone-600 text-lg">PhD Student, TU Munich</p>
            </div>
          </div>
          <div class="flex flex-wrap justify-center gap-2">
            <a aria-label="Email" class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-stone-200 hover:border-stone-300 bg-stone-50 hover:bg-white transition text-stone-700" href={`mailto:${cvData.email}`}>
              <Mail size={15} />
            </a>
            <a aria-label="Google Scholar" class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-stone-200 hover:border-stone-300 bg-stone-50 hover:bg-white transition text-stone-700" href={`https://scholar.google.com/citations?user=${cvData.social.scholar}`} target="_blank" rel="noreferrer">
              <GraduationCap size={15} />
            </a>
            <a aria-label="GitHub" class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-stone-200 hover:border-stone-300 bg-stone-50 hover:bg-white transition text-stone-700" href={`https://github.com/${cvData.social.github}`} target="_blank" rel="noreferrer">
              <Github size={15} />
            </a>
            <a aria-label="LinkedIn" class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-stone-200 hover:border-stone-300 bg-stone-50 hover:bg-white transition text-stone-700" href={`https://linkedin.com/in/${cvData.social.linkedin}`} target="_blank" rel="noreferrer">
              <Linkedin size={15} />
            </a>
          </div>
          <div class="pt-4 border-t border-stone-200">
            <nav class="flex flex-wrap gap-2 text-sm" role="tablist" aria-label="Section navigation">
              <a class="inline-flex items-center px-3 py-1.5 rounded-lg border border-stone-200 bg-stone-50 hover:bg-white hover:border-stone-300 transition" href="#about" role="tab">About</a>
              <a class="inline-flex items-center px-3 py-1.5 rounded-lg border border-stone-200 bg-stone-50 hover:bg-white hover:border-stone-300 transition" href="#publications" role="tab">Publications</a>
              <a class="inline-flex items-center px-3 py-1.5 rounded-lg border border-stone-200 bg-stone-50 hover:bg-white hover:border-stone-300 transition" href="#experience" role="tab">Experience</a>
              <a class="inline-flex items-center px-3 py-1.5 rounded-lg border border-stone-200 bg-stone-50 hover:bg-white hover:border-stone-300 transition" href="#education" role="tab">Education</a>
            </nav>
          </div>
        </aside>

        <!-- Main Content -->
        <div class="space-y-14">
          <section id="about" class="space-y-4">
            <p class="text-sm uppercase tracking-[0.2em] text-stone-500">About</p>
            <p class="text-lg text-stone-700 leading-relaxed">
              I'm a PhD student with the <a class="underline hover:text-stone-900" href="https://dse.in.tum.de/" target="_blank" rel="noreferrer">Systems Research Group</a> at TU Munich, advised by Prof. Pramod Bhatotia. My work spans compiler IRs, runtime systems, and tools that make quantum accelerators usable alongside classical compute.
            </p>
          </section>

          <section id="publications" class="space-y-6">
            <div class="flex items-baseline justify-between gap-3">
              <div>
                <h2 class="text-2xl font-bold">Recent Publications</h2>
              </div>
              <a href={`https://scholar.google.com/citations?user=${cvData.social.scholar}`} target="_blank" rel="noreferrer" class="text-sm text-stone-600 hover:text-stone-900 underline">Google Scholar</a>
            </div>
            <div class="space-y-6">
              {cvData.publications.map(pub => (
                <article class="p-4 rounded-xl border border-stone-200 bg-white/70">
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <h3 class="text-xl font-semibold leading-snug">
                      <a class="hover:text-stone-700 underline" href={pub.links.paper} target="_blank" rel="noreferrer">{pub.title}</a>
                    </h3>
                    {pub.venue && (
                      <span class="text-xs font-medium px-3 py-1 rounded-full bg-stone-100 text-stone-600 border border-stone-200">{pub.venue}</span>
                    )}
                  </div>
                  <p class="text-sm text-stone-600 mt-2">
                    {pub.authors.map((author, idx) => (
                      <>
                        {author === cvData.name ? <span class="font-semibold">{author}</span> : author}
                        {idx < pub.authors.length - 1 ? ', ' : ''}
                      </>
                    ))}
                  </p>
                  {pub.journal && (
                    <p class="text-sm text-stone-500 mt-2">
                      {pub.venueUrl ? (
                        <a class="text-stone-500 hover:text-stone-800 hover:underline underline-offset-2 decoration-stone-300" href={pub.venueUrl} target="_blank" rel="noreferrer">{pub.journal}</a>
                      ) : (
                        pub.journal
                      )}
                    </p>
                  )}
                </article>
              ))}
            </div>
          </section>

          <section id="experience" class="space-y-6">
            <div class="flex items-baseline justify-between gap-3">
              <div>
                <h2 class="text-3xl font-bold">Experience</h2>
              </div>
            </div>
            <div class="space-y-6">
              {cvData.experience.map(exp => (
                <article class="p-4 rounded-xl border border-stone-200 bg-white/70">
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div>
                      <h3 class="text-xl font-semibold leading-snug">{exp.position}</h3>
                      <p class="text-sm text-stone-600">
                        <a class="hover:text-stone-900" href={exp.companyUrl} target="_blank" rel="noreferrer">{exp.company}</a> · {exp.location}
                      </p>
                    </div>
                    <span class="text-sm text-stone-500 whitespace-nowrap">{exp.period}</span>
                  </div>
                  {exp.details && (
                    <ul class="mt-3 space-y-1 text-stone-700 text-sm">
                      {exp.details.map(detail => (
                        <li class="flex items-start gap-2">
                          <span class="text-stone-400">•</span>
                          <span class="leading-relaxed">{detail}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </article>
              ))}
            </div>
          </section>

          <section id="education" class="space-y-6">
            <div class="flex items-baseline justify-between gap-3">
              <div>
                <h2 class="text-3xl font-bold">Education</h2>
              </div>
            </div>
            <div class="space-y-6">
              {cvData.education.map(edu => (
                <article class="p-4 rounded-xl border border-stone-200 bg-white/70">
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div>
                      <h3 class="text-xl font-semibold leading-snug">{edu.degree}</h3>
                      <p class="text-sm text-stone-600">
                        <a class="hover:text-stone-900" href={edu.institutionUrl} target="_blank" rel="noreferrer">{edu.institution}</a>
                      </p>
                    </div>
                    <span class="text-sm text-stone-500 whitespace-nowrap">{edu.period}</span>
                  </div>
                  {edu.thesis && (
                    <div class="mt-3 text-sm text-stone-700 flex items-center gap-2">
                      <FileText size={14} />
                      {edu.thesisLink ? (
                        <a class="underline hover:text-stone-900" href={edu.thesisLink} target="_blank" rel="noreferrer">{edu.thesis}</a>
                      ) : (
                        <span>{edu.thesis}</span>
                      )}
                    </div>
                  )}
                  {edu.description && <p class="text-sm text-stone-600 mt-2">{edu.description}</p>}
                </article>
              ))}
            </div>
          </section>
        </div>
      </div>

      <footer class="pt-12 text-center text-sm text-stone-500">Last updated: December 2025</footer>
    </main>
  </body>
</html>
